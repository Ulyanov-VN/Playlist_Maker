<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="13dp"
    android:paddingEnd="13dp"
    android:paddingTop="16dp">

    <!-- Обложка -->
    <ImageView
        android:id="@+id/artwork"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_gravity="center_vertical"
        android:scaleType="centerCrop" />

    <!-- Центр: имя трека + (артист • длительность) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Название трека -->
        <TextView
            android:id="@+id/trackName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorControlNormal"
            android:letterSpacing="0"
            android:textSize="@dimen/text_size_AlbumName"
            android:textFontWeight="400"
            android:fontFamily="@font/ys_text_regular"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Артист • Длительность -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:baselineAligned="true">

            <!-- Имя исполнителя: занимает всё доступное, режем с конца -->
            <TextView
                android:id="@+id/artistName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorAccent"
                android:textSize="@dimen/text_size_AlbumGroupTime"
                android:textFontWeight="400"
                android:fontFamily="@font/ys_text_regular"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Точка-разделитель -->
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:src="@drawable/ellipse_1"
                app:tint="?attr/colorAccent" />

            <!-- Длительность: всегда видна -->
            <TextView
                android:id="@+id/trackTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorAccent"
                android:textSize="@dimen/text_size_AlbumGroupTime"
                android:textFontWeight="400"
                android:fontFamily="@font/ys_text_regular" />
        </LinearLayout>
    </LinearLayout>

    <!-- Стрелка справа -->
    <ImageView
        style="@style/ImageViewSettings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:contentDescription="@null"
        android:src="@drawable/arrow" />

</LinearLayout>
